## latent variables
LV1 =~ x1  + x2  + x3
LV2 =~ x4  + x5  + x6
LV3 =~ x7  + x8  + x9
"
model3 <-
"
## regressions
LV3 ~ LV1
LV2 ~ LV1 + LV3
## latent variables
LV1 =~ x1  + x2  + x3
LV2 =~ x4  + x5  + x6
LV3 =~ x7  + x8  + x9
"
model4 <-
"
## regressions
LV1 ~ LV3
LV2 ~ LV1 + LV3
## latent variables
LV1 =~ x1  + x2  + x3
LV2 =~ x4  + x5  + x6
LV3 =~ x7  + x8  + x9
"
model5 <-
"
## regressions
LV3 ~ LV2
LV1 ~ LV2 + LV3
## latent variables
LV1 =~ x1  + x2  + x3
LV2 =~ x4  + x5  + x6
LV3 =~ x7  + x8  + x9
"
model6 <-
"
## regressions
LV2 ~ LV3
LV1 ~ LV2 + LV3
## latent variables
LV1 =~ x1  + x2  + x3
LV2 =~ x4  + x5  + x6
LV3 =~ x7  + x8  + x9
"
## EXAMPLE: Sextet of fitted LV models
model1_fit <- sem(model1, data=simData, fixed.x = FALSE, missing = "ml")
model2_fit <- sem(model2, data=simData, fixed.x = FALSE, missing = "ml")
model3_fit <- sem(model3, data=simData, fixed.x = FALSE, missing = "ml")
model4_fit <- sem(model4, data=simData, fixed.x = FALSE, missing = "ml")
model5_fit <- sem(model5, data=simData, fixed.x = FALSE, missing = "ml")
model6_fit <- sem(model6, data=simData, fixed.x = FALSE, missing = "ml")
## EXAMPLE: mvpt() output
mvpt_output <- mvpt(lavaan_model = model1, path = "LV3 ~ LV1", data = simData, showplots = TRUE)
#### THEORY TESTS (maybe add one more about automatics covs) ####
## Functionality of equal fit indices theory across SEXTET (within tolerance)
model_fit_list <- list(model1_fit, model2_fit, model3_fit, model4_fit, model5_fit, model6_fit)
fm_list <- lapply(model_fit_list, function(f) unname(fitMeasures(f, c("cfi","tli","rmsea","srmr"))))
expect_true(all(sapply(fm_list, function(x) isTRUE(all.equal(fm_list[[1]], x, tolerance = 1e-6)))))
#### MAIN FUNCTION: mvpt(lavaan_model, path, data) ####
## Functionality with LV model
expect_silent(mvpt_output)
## Functionality with LV model, reversal = TRUE
expect_silent(mvpt(lavaan_model = model1, path = "LV3 ~ LV1", data = simData, showplots = TRUE, reversal = TRUE))
## Functionality with LV model, list()
expect_silent(mvpt(lavaan_model = list(model1, model2), path = "LV3 ~ LV1", data = simData, showplots = TRUE))
## Functionality without LVs
expect_silent(mvpt(lavaan_model = corr_model, path = "C3 ~ C1", data = simData, showplots = TRUE))
## Functionality without LVs, reversal = TRUE (must be fam of size M=6)
M <- mvpt(lavaan_model = corr_model, path = "C3 ~ C1", data = simData, showplots = TRUE, reversal = TRUE)$CORE_comp[[1]]
expect_equal(M == 6, TRUE)
## Functionality without LVs, list() with one model nested in the next (where path match is implied)
expect_silent(mvpt(lavaan_model = list("C3 ~ C1", "C3 ~ C2 + C1\n C2~C1"), path = "C3 ~ C1", data = simData, showplots = TRUE))
## Non-functionality due to negative variances (Heywood cases)
set.seed(123); n <- 100
f1 <- rnorm(n)
f2 <- 0.80 * f1 + rnorm(n, sd = 0.30)
y1 <- 1.00 * f1 + rnorm(n, sd = 0.01) ## perfect indicator
y2 <- 0.40 * f1 + rnorm(n, sd = 0.30)
y3 <- 0.40 * f2 + rnorm(n, sd = 0.30)
y4 <- 0.40 * f2 + rnorm(n, sd = 0.30)
dat_hey <- data.frame(y1, y2, y3, y4)
model_hey1 <-
'
f1 =~ y1 + y2
f2 =~ y3 + y4
f2 ~ f1
'
model_hey2 <-
'
f1 =~ y1 + y3
f2 =~ y2 + y4
f2 ~ f1
'
lavaan_model <- list(model_hey1, model_hey2)
expect_error(mvpt(lavaan_model, path = "f2 ~ f1", data = dat_hey))
## Non-functionality due to non-positive definite cov matrix
set.seed(123); n <- 100
x1 <- rnorm(n)
x2 <- x1          # perfect correlation
x3 <- rnorm(n)
y  <- rnorm(n)
data <- data.frame(x1, x2, x3, y)
lavaan_model <-
'
y ~ x1 + x2
x2 ~ x1
'
path = "y ~ x1"
expect_error(mvpt(lavaan_model, path = "y ~ x1", data))
## Non-functionality due wrong input object
expect_error(mvpt(lavaan_model = model1_fit, path = "C3~C1", data = simData))
## Non-functionality due non-lavaan formatting error
err_model <-
"
C2 + C1
C3 ~ C1 + C2
"
expect_error(mvpt(lavaan_model = list(corr_model, err_model), path = "C3~C1", data = simData, showplots = TRUE))
## Non-functionality message due to covariance specification (update pending)
err_model <-
"
C2 ~~ C1
C3 ~ C1 + C2
"
expect_error(mvpt(lavaan_model = list(corr_model, err_model), path = "C3~C1", data = simData, showplots = TRUE))
## Non-functionality due to label usage
err_model <-
"
C2 ~ a*C1
C3 ~ C1 + C2
"
expect_error(mvpt(lavaan_model = list(corr_model, err_model), path = "C3~C1", data = simData, showplots = TRUE))
## Non-functionality due to path misspecification
expect_error(mvpt(lavaan_model = corr_model, path = "C3->C1", data = simData))
## Non-functionality due to path not being in model
expect_error(mvpt(lavaan_model = corr_model, path = "C1~C3", data = simData))
## Non-functionality due to list() input and specifying a path that is not shared
expect_error(mvpt(lavaan_model = list(model1, model4), path = "LV3 ~ LV1", data = simData, showplots = TRUE))
#### MAIN FUNCTION: mvptRank(mvpt_output) ####
## Functionality assuming mvpt() functionality
expect_silent(mvptRank(mvpt_output))
## Non-functionality assuming non mvpt class
expect_error(mvptRank(model1_fit))
#### MAIN FUNCTION: mvptZoom(mvpt_output, index) ####
## Functionality assuming mvpt() functionality
expect_silent(mvptZoom(mvpt_output, index=1))
## Non-functionality assuming non mvpt class
expect_error(mvptZoom(model1_fit, index=1))
## Non-functionality due to out of bounds index
expect_error(mvptZoom(mvpt_output, index=7))
#### HELPER FUNCTION: dagu(LAV_list, path, reversal) ####
LAV_list <- "LV3 ~ LV1"
path <- "LV3 ~ LV1"
## Non-functionality message if user-given model is orphan
expect_message(mvpt:::dagu(LAV_list, path))
#### HELPER FUNCTION: auto_sem(fam_lavaan_ready, data, missing = "ml", estimator = "ML") ####
fam_lavaan_ready <- mvpt:::dagu(LAV_list = model1, path = "LV3 ~ LV1", reversal = FALSE)$fam_lavaan_ready
data <- simData
## Non-functionality if default missing argument is changed
expect_error(auto_sem(fam_lavaan_ready, data, missing = "listwise"))
## Non-functionality if default estimator argument is changed
expect_error(auto_sem(fam_lavaan_ready, data, estimator = "WLS"))
#### HELPER FUNCTION: calc_A(SEMfitted), calc_sc(SEMfitted), & calc_B(sc1, sc2, n) ####
SEMfitted <- model1_fit
sc1 <- mvpt:::calc_sc(SEMfitted)
sc2 <- mvpt:::calc_sc(SEMfitted)
n <- nobs(SEMfitted)
#### HELPER FUNCTION: vw_core(SEMfitted_list, path, reversal) ####
SEMfitted_list <- list(model1_fit, model2_fit, model3_fit, model4_fit, model5_fit)
path <- "LV3 ~ LV1"
reversal <- FALSE; reversal <- TRUE
base_model <- "
ind60 =~ x1 + x2 + x3
dem60 =~ y1 + y2 + y3 + y4
dem65 =~ y5 + y6 + y7 + y8
dem60 ~ ind60
dem65 ~ ind60 + dem60
"
base_path   <- "dem60 ~ ind60"
base_output <- mvpt(base_model, base_path, data = PoliticalDemocracy)
#######################################
## 1. mvpt() — lavaan_model argument ##
#######################################
## bad model syntax
tryCatch(mvpt("this is not lavaan syntax $$$$", base_path, data = PoliticalDemocracy))
test_that("mvpt: bad model syntax throws an error", {
expect_error(
mvpt("this is not lavaan syntax $$$$", base_path, data = PoliticalDemocracy),
regexp = "Error returned by lavaan"  # with error info from lavaan and some instruction
)
})
#######################
## Guardrail Testing ##
#######################
library(testthat)
data(PoliticalDemocracy, package = "lavaan")
#######################################
## 1. mvpt() — lavaan_model argument ##
#######################################
## bad model syntax
tryCatch(mvpt("this is not lavaan syntax $$$$", base_path, data = PoliticalDemocracy))
test_that("mvpt: bad model syntax throws an error", {
expect_error(
mvpt("this is not lavaan syntax $$$$", base_path, data = PoliticalDemocracy),
regexp = "Error returned by lavaan"  # with error info from lavaan and some instruction
)
})
## POTENTIAL GAP: add error message saying user must add at least one regression path?
## Example message:
# if (!grepl("~", gsub("=~", "", lavaan_model))) {
#   stop("The model must contain at least one regression path (Y ~ X).")
# }
## "urgency" for change: 3/5
test_that("mvpt: model with only measurement (no regression) throws informative error or returns NULL", {
## No ~ paths, so no path to test — function should not silently succeed
measure_only_model <- "
ind60 =~ x1 + x2 + x3
dem60 =~ y1 + y2 + y3 + y4
"
expect_error(
mvpt(measure_only_model, "dem60 ~ ind60", data = PoliticalDemocracy),
regexp = "Specified path must be present in model specification."
)
})
## empty model string
test_that("mvpt: empty model string throws an error", {
expect_error(
mvpt("", base_path, data = PoliticalDemocracy)
)
})
###############################
## 2. mvpt() — path argument ##
###############################
## incorrect path variables
test_that("mvpt: path variables not in the model throws an error", {
expect_error(
mvpt(base_model, "FAKE ~ VARIABLES", data = PoliticalDemocracy)
)
})
## GAP: there is a typo in the message. "syntax" is misspelled
## It may also be helpful to users to have a specific message about having multiple predictors
## Suggested message:
# An MVP Test could not be computed using the provided lavaan model syntax
# and path. No other models could be generated for comparison, thus halting
# computation of a test statistic. Note: the path argument expects a single
# predictor (e.g. "Y ~ X"). If you supplied multiple predictors (e.g. "Y ~ X + Z"),
# try specifying just one path at a time.
## "urgency" for change: 3/5
## multiple predictors
test_that("mvpt: path with multiple predictors (Y ~ X + Z) is rejected", {
## Current check only looks for one '~', so "Y ~ X + Z" passes it — this should not be allowed
expect_error(
mvpt(base_model, "dem60 ~ ind60 + dem65", data = PoliticalDemocracy),
regexp = 'Specified path must be a character string, for example: "Y ~ X"'          # message should mention single path
)
})
## Potential GAP: could be helpful to have hint as to why it doesn't work
## same typo
## "urgency" for change: 1/5
## incorrect syntax
test_that("mvpt: measurement syntax in path (=~) is rejected", {
expect_error(
mvpt(base_model, "dem60 =~ y1", data = PoliticalDemocracy),
regexp = 'Specified path must be a character string, for example: "Y ~ X"'
)
})
## Potential GAP: could be helpful to have hint as to why it doesn't work
## "urgency" for change: 1/5
## missing left hand
test_that("mvpt: path with missing left-hand side is rejected", {
expect_error(
mvpt(base_model, "~ ind60", data = PoliticalDemocracy)
)
})
## missing right hand
test_that("mvpt: path with missing right-hand side is rejected", {
expect_error(
mvpt(base_model, "dem60 ~", data = PoliticalDemocracy)
)
})
## incorrect syntax -- no ~
test_that("mvpt: path with no '~' is rejected", {
expect_error(
mvpt(base_model, "dem60 ind60", data = PoliticalDemocracy),
regexp = "~"
)
})
## numerical path -- incorrect path type
test_that("mvpt: non-character path is rejected", {
expect_error(
mvpt(base_model, 123, data = PoliticalDemocracy),
regexp = "character"
)
expect_error(
mvpt(base_model, NULL, data = PoliticalDemocracy)
)
})
###############################
## 3. mvpt() — data argument ##
###############################
## missing data reference
test_that("mvpt: no data throws an informative error", {
expect_error(
mvpt(base_model, base_path),
regexp = "data"      # error message should mention data
)
})
## matrix data permitted
test_that("mvpt: matrix data throws an informative error or coerces cleanly", {
mat_data <- as.matrix(PoliticalDemocracy)
## Either it coerces and works, or it fails clearly — it should NOT crash cryptically
result <- tryCatch(
mvpt(base_model, base_path, data = mat_data),
error = function(e) e
)
if (inherits(result, "error")) {
expect_match(conditionMessage(result), "data.frame|data", ignore.case = TRUE)
} else {
expect_s3_class(result, "mvpt")
}
})
## tibble data permitted
test_that("mvpt: tibble data works without error", {
tbl_data <- tibble::as_tibble(PoliticalDemocracy)
expect_no_error(
mvpt(base_model, base_path, data = tbl_data)
)
})
## data with missing values permitted
test_that("mvpt: data with NA rows produces an informative warning or handles gracefully", {
na_data <- PoliticalDemocracy
na_data[1:5, "x1"] <- NA
## Should not crash silently; either warns or errors clearly
expect_no_error(
mvpt(base_model, base_path, data = na_data)
)
})
## data with incorrect variables names
test_that("mvpt: data with wrong column names (model vars not in data) throws error", {
wrong_data <- PoliticalDemocracy
names(wrong_data)[1] <- "WRONG_NAME"
expect_error(
mvpt(base_model, base_path, data = wrong_data)
)
})
## small sample size
test_that("mvpt: very small n (fewer rows than free parameters) produces informative error", {
tiny_data <- PoliticalDemocracy[1:8, ]
expect_error(
mvpt(base_model, base_path, data = tiny_data)
)
})
## how is factor handled
test_that("mvpt: factor column in a modeled variable throws informative error", {
factor_data <- PoliticalDemocracy
factor_data$x1 <- as.factor(factor_data$x1)
expect_error(
mvpt(base_model, base_path, data = factor_data)
)
})
####################################
## 4. mvpt() — showplots argument ##
####################################
## yes instead of T/F for showplot
## behaves as expected
test_that("mvpt: non-logical showplots is rejected", {
expect_error(
print(mvpt(base_model, base_path, data = PoliticalDemocracy, showplots = "yes")), regexp = "argument is not interpretable as logical"
)
})
##################################
## 5. mvpt() — output structure ##
##################################
## checking class
test_that("mvpt: output has class 'mvpt'", {
expect_s3_class(base_output, "mvpt")
})
## output has expected components
test_that("mvpt: output contains expected named components", {
expect_named(base_output, c("FIGURE_list", "SEMfitted_list", "CORE_comp", "showplots", "reversal"),
ignore.order = TRUE)
})
## output handles being saved well
test_that("mvpt: output survives saveRDS/readRDS round-trip and class is preserved", {
tmp <- tempfile(fileext = ".rds")
saveRDS(base_output, tmp)
reloaded <- readRDS(tmp)
expect_s3_class(reloaded, "mvpt")
unlink(tmp)
})
######################################
## 6. mvptZoom() — input validation ##
######################################
## what happens with non mvpt
## Potential GAP: perhaps add more informative message like:
# mvptZoom <- function(mvpt_output, index) {
#
#   if (!inherits(mvpt_output, "mvpt")) {
#     stop("'mvpt_output' must be an object of class 'mvpt', produced by mvpt(). ",
#          "Did you pass the right object?")
#   }
#
#   # ... rest of function
# }
## urgency for change: 1/5
test_that("mvptZoom: non-mvpt input throws informative error", {
expect_error(mvptZoom(list(), index = 1),         regexp = "mvpt")
expect_error(mvptZoom("not_mvpt_output", index = 1), regexp = "mvpt")
expect_error(mvptZoom(NULL, index = 1),            regexp = "mvpt")
})
## missing index
## Potential GAP: I think it would be helpful either to set default index or
## include a message like the following:
# if (missing(index)) {
#   stop("'index' is required. Please supply a model number (e.g. index = 1). ",
#        "Model 1 is always the original model you supplied.")
# }
## urgency for change: 4/5
test_that("mvptZoom: missing index throws informative error", {
expect_error(mvptZoom(base_output), regexp = "index")
})
## too high index
## Potential GAP: this is related to above. I think a message about the limit
## for index would be helpful. Suggestion to address:
# n_models <- length(mvpt_output$FIGURE_list)
#
# if (!is.numeric(index) || length(index) != 1 || index != as.integer(index) || index < 1) {
#   stop("'index' must be a single positive whole number.")
# }
# if (index > n_models) {
#   stop("'index' is out of bounds. You requested model ", index,
#        " but only ", n_models, " models were generated.")
# }
## urgency for change: 4/5
test_that("mvptZoom: index out of bounds throws informative error", {
n_models <- length(base_output$FIGURE_list)
expect_error(
mvptZoom(base_output, index = n_models + 1),
regexp = "index|bounds|models"
)
})
## index is 0
## Potential GAP: Same as abpve
## suggestion:
# if (!is.numeric(index) || length(index) != 1 || index != as.integer(index) || index < 1) {
#   stop("'index' must be a single positive whole number.")
# }
## urgency for change: 4/5
test_that("mvptZoom: index = 0 throws informative error", {
expect_error(mvptZoom(base_output, index = 0), regexp = "index")
})
## Negative index
## Potential GAP: Same as other index
## suggestion folded into index 0 suggestion
## urgency for change: 4/5
test_that("mvptZoom: negative index throws informative error", {
expect_error(mvptZoom(base_output, index = -1), regexp = "index")
})
## Non integer
## Potential GAP: also addressed in index 0 solution
## urgency for change 4/5
test_that("mvptZoom: non-integer index throws informative error", {
expect_error(mvptZoom(base_output, index = 1.5), regexp = "integer|whole")
expect_error(mvptZoom(base_output, index = "1"), regexp = "integer|numeric")
})
## index = 1 works
test_that("mvptZoom: valid index = 1 works without error", {
expect_no_error(mvptZoom(base_output, index = 1))
})
######################################################
## 7. mvptRank() — input validation and correctness ##
######################################################
## non mvpt
## Potential GAP: perhaps add more informative message like:
# mvptRank <- function(mvpt_output) {
#
#   if (!inherits(mvpt_output, "mvpt")) {
#     stop("'mvpt_output' must be an object of class 'mvpt', produced by mvpt(). ",
#          "Did you pass the right object?")
#   }
#
#   # ... rest of function
# }
## urgency for change: 1/5
test_that("mvptRank: non-mvpt input throws informative error", {
expect_error(mvptRank(list()),             regexp = "mvpt")
expect_error(mvptRank("not_mvpt_output"), regexp = "mvpt")
expect_error(mvptRank(NULL),              regexp = "mvpt")
})
## correct sort output rows
test_that("mvptRank: output rows are in ascending order of path value", {
result <- mvptRank(base_output)
path_vals <- as.numeric(result[, 1])
expect_equal(path_vals, sort(path_vals),
info = "mvptRank output should be sorted ascending by path value")
})
## all models represented in output
test_that("mvptRank: all models are represented in the output", {
result     <- mvptRank(base_output)
all_models <- names(base_output$CORE_comp$sharedparamvals)
ranked_models <- unlist(strsplit(result[, 2], ", "))
expect_setequal(ranked_models, all_models)
})
## handles ties without errors
test_that("mvptRank: handles ties (all models with same path value) without error", {
## Manually construct a degenerate CORE_comp where all path values are equal
fake_output <- base_output
fake_output$CORE_comp$sharedparamvals <- c(M1 = 0.5, M2 = 0.5, M3 = 0.5)
expect_no_error(mvptRank(fake_output))
})
